ANTHROPIC_API_KEY=your_key_here
ENVIRONMENT=development
MAX_TOKENS=4096

# Optional: wire up real web search (get a free key at https://app.tavily.com)
TAVILY_API_KEY=

# Optional: enable API key auth on all /api/* routes
PLATFORM_API_KEY=

# SQLite database path (defaults to /data/sessions.db)
DB_PATH=./data/sessions.db
